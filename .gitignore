# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl

# Virtual environments
.venv/
venv/
env/

# Testing
.pytest_cache/
.pytest_cache_local/
.pytest_tmp/
.coverage
htmlcov/
.tox/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Runtime data (never commit user data)
data/
*.db
*.db-shm
*.db-wal
*.bin
*.log
logs/
backups/

# Config (user-specific)
config.toml

# Internal dev docs (roadmap, plans, prompting guide)
docs/plans/
.claude/ROADMAP.md
.claude/PROMPTING-GUIDE.md
.claude/settings.local.json
.claude/prompts/

# Temporary output files
ruff_output.txt
test_output.txt
.tmp_novelty_eval_runtime/

# Benchmark data and results (user-provided)
benchmarks/data/*.json
benchmarks/results/*.json
!benchmarks/data/.gitkeep
!benchmarks/results/.gitkeep
